{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "leyline-opencode",
  "version": "0.1.5",
  "description": "OpenCode Workflow Kernel plugin for deterministic phase-gated AI coding workflows.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forsonny/leyline-opencode.git"
  },
  "bugs": {
    "url": "https://github.com/forsonny/leyline-opencode/issues"
  },
  "homepage": "https://github.com/forsonny/leyline-opencode#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "prepare": "bun run build",
    "prepack": "bun run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "workflow",
    "worktree",
    "ai-coding"
  ],
  "engines": {
    "opencode": ">=1.14.22",
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.22",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
